{
  "name": "ManagerTrends",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "description": "Email of the manager"
    },
    "energy_trend": {
      "type": "string",
      "enum": [
        "improving",
        "stable",
        "declining",
        "insufficient_data"
      ],
      "description": "14-day energy trend direction"
    },
    "confidence_trend": {
      "type": "string",
      "enum": [
        "improving",
        "stable",
        "declining",
        "insufficient_data"
      ],
      "description": "14-day confidence trend direction"
    },
    "resilience_trend": {
      "type": "string",
      "enum": [
        "improving",
        "stable",
        "declining",
        "insufficient_data"
      ],
      "description": "14-day resilience trend direction"
    },
    "motivation_trend": {
      "type": "string",
      "enum": [
        "improving",
        "stable",
        "declining",
        "insufficient_data"
      ],
      "description": "14-day motivation trend direction"
    },
    "optimism_trend": {
      "type": "string",
      "enum": [
        "improving",
        "stable",
        "declining",
        "insufficient_data"
      ],
      "description": "14-day optimism trend direction"
    },
    "overload_pattern_strength": {
      "type": "number",
      "description": "Composite overload pattern strength (0-100)"
    },
    "stretch_frequency_14d": {
      "type": "number",
      "description": "Number of stretch/drain days in last 14 days"
    },
    "operator_risk_trajectory": {
      "type": "string",
      "enum": [
        "improving",
        "stable",
        "declining",
        "increasing",
        "insufficient_data"
      ],
      "description": "Operator risk trajectory direction"
    },
    "overload_acknowledgment_rate": {
      "type": "number",
      "description": "Rate of overload acknowledgment (0-1)"
    },
    "summary_7d": {
      "type": "string",
      "description": "7-day natural language summary"
    },
    "summary_28d": {
      "type": "string",
      "description": "28-day natural language summary"
    },
    "trend_narrative": {
      "type": "string",
      "description": "LLM-generated trend narrative"
    },
    "last_trend_computed_at": {
      "type": "string",
      "format": "date-time",
      "description": "When trends were last computed"
    },
    "data_points_14d": {
      "type": "number",
      "description": "Number of data points in 14-day window"
    },
    "data_points_28d": {
      "type": "number",
      "description": "Number of data points in 28-day window"
    },
    "learning_stall_detected": {
      "type": "boolean",
      "description": "Whether learning stall is detected"
    },
    "delegation_intent_count_7d": {
      "type": "number",
      "description": "Number of delegation intentions in last 7 days"
    },
    "delegation_gap_count_7d": {
      "type": "number",
      "description": "Number of delegation gaps in last 7 days"
    },
    "identity_friction_signals": {
      "type": "number",
      "description": "Number of identity friction signals detected"
    },
    "identity_friction_active": {
      "type": "boolean",
      "description": "Whether identity friction is currently active"
    },
    "confidence_declining_days": {
      "type": "number",
      "description": "Consecutive days confidence has been declining"
    },
    "avg_load_7d": {
      "type": "number",
      "description": "7-day average load check-in score (1-5)"
    },
    "avg_growth_7d": {
      "type": "number",
      "description": "7-day average growth check-in score (1-5)"
    },
    "workload_growth_divergence_days": {
      "type": "number",
      "description": "Count of days where load >= 4 AND growth <= 2"
    },
    "behavioral_commitments_7d": {
      "type": "number",
      "description": "Count of behavioral_commitment Goals created in last 7 days"
    },
    "visibility_level": {
      "type": "string",
      "enum": [
        "private"
      ],
      "default": "private",
      "description": "Visibility level (always private)"
    },
    "client_id": {
      "type": "string",
      "description": "Client ID for multi-tenant support"
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Optional description"
    }
  },
  "required": [
    "user_email"
  ],
  "rls": {
    "read": {
      "user_email": "{{user.email}}"
    },
    "write": {}
  }
}