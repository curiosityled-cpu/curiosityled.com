{
  "name": "ManagerTrends",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "description": "Email of the manager this trend record belongs to"
    },
    "confidence_trend": {
      "type": "string",
      "enum": [
        "improving",
        "stable",
        "declining",
        "insufficient_data"
      ],
      "description": "Direction of confidence_today responses over last 14 days. ALWAYS PRIVATE."
    },
    "energy_trend": {
      "type": "string",
      "enum": [
        "improving",
        "stable",
        "declining",
        "insufficient_data"
      ],
      "description": "Direction of energy_level responses over last 14 days. ALWAYS PRIVATE."
    },
    "resilience_trend": {
      "type": "string",
      "enum": [
        "improving",
        "stable",
        "declining",
        "insufficient_data"
      ],
      "description": "Direction of resilience_signal responses over last 14 days. ALWAYS PRIVATE."
    },
    "identity_friction_signals": {
      "type": "number",
      "description": "Count of check-ins in last 7 days where identity_friction was true. ALWAYS PRIVATE."
    },
    "identity_friction_active": {
      "type": "boolean",
      "default": false,
      "description": "Whether the manager is currently in an active identity friction period. ALWAYS PRIVATE."
    },
    "overload_pattern_strength": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Composite score reflecting frequency and intensity of overload signals over 28 days (0-100). ALWAYS PRIVATE."
    },
    "stretch_frequency_14d": {
      "type": "number",
      "description": "Count of check-ins in last 14 days where energy_level was stretched or drained. ALWAYS PRIVATE."
    },
    "operator_risk_trajectory": {
      "type": "string",
      "enum": [
        "increasing",
        "stable",
        "decreasing",
        "insufficient_data"
      ],
      "description": "Direction of operator_mode_risk_score over last 7 days"
    },
    "overload_acknowledgment_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Proportion of overload prompts answered very_much or somewhat in last 28 days. ALWAYS PRIVATE."
    },
    "summary_7d": {
      "type": "string",
      "description": "Plain-language summary of the last 7 days for Atreus context. ALWAYS PRIVATE."
    },
    "summary_28d": {
      "type": "string",
      "description": "Plain-language summary of the last 28 days for Atreus context. ALWAYS PRIVATE."
    },
    "trend_narrative": {
      "type": "string",
      "description": "Short LLM-generated interpretive sentence for Atreus to read. Uses only observational, self-report-respecting language. ALWAYS PRIVATE."
    },
    "last_trend_computed_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this record was last updated"
    },
    "data_points_14d": {
      "type": "number",
      "description": "Number of check-ins in last 14 days (used to qualify confidence of trends)"
    },
    "data_points_28d": {
      "type": "number",
      "description": "Number of check-ins in last 28 days"
    },
    "learning_stall_detected": {
      "type": "boolean",
      "default": false,
      "description": "Whether learning inertia has been increasing week-over-week"
    },
    "delegation_intent_count_7d": {
      "type": "number",
      "description": "How many times delegation was declared as morning intent in last 7 days"
    },
    "delegation_gap_count_7d": {
      "type": "number",
      "description": "How many times delegation intent did not match observed behavior in last 7 days"
    },
    "client_id": {
      "type": "string",
      "description": "Client ID for multi-tenant support"
    }
  },
  "required": [
    "user_email"
  ],
  "rls": {
    "read": {
      "user_email": "{{user.email}}"
    },
    "write": {}
  }
}