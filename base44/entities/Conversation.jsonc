{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Conversation title or topic"
    },
    "type": {
      "type": "string",
      "enum": [
        "post_assessment",
        "assigned_learning",
        "proactive_checkin",
        "general"
      ],
      "description": "Type of conversation"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "completed",
        "paused"
      ],
      "default": "active",
      "description": "Current status of the conversation"
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant"
            ]
          },
          "content": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "resources": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of learning resource IDs referenced in this message"
          }
        }
      },
      "description": "Array of messages in the conversation"
    },
    "context": {
      "type": "object",
      "additionalProperties": true,
      "description": "Conversation context (assessment data, assigned learning ID, etc.)"
    },
    "learning_progress": {
      "type": "object",
      "additionalProperties": true,
      "description": "Track progress through learning objectives"
    },
    "last_activity": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of last message"
    }
  },
  "required": [
    "title",
    "type"
  ],
  "rls": {
    "read": {
      "created_by": "{{user.email}}"
    },
    "write": {
      "created_by": "{{user.email}}"
    }
  }
}