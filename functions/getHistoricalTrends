import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

/**
 * Retrieves historical trend data from stored analytics snapshots
 */
Deno.serve(async (req) => {
  try {
    const base44 = createClientFromRequest(req);
    const user = await base44.auth.me();

    if (!user) {
      return Response.json({ error: 'Unauthorized' }, { status: 401 });
    }

    // Check permissions
    const hasAccess = ['User Level 3', 'Admin Level 2', 'Super Administrator', 'Platform Admin'].includes(user.app_role);
    
    if (!hasAccess) {
      return Response.json({ error: 'Insufficient permissions' }, { status: 403 });
    }

    const { timeframe = '6months', metric = 'all' } = await req.json();

    // Calculate date range
    const getDateRange = (timeframe) => {
      const endDate = new Date();
      const startDate = new Date();
      
      switch(timeframe) {
        case '3months':
          startDate.setMonth(startDate.getMonth() - 3);
          break;
        case '6months':
          startDate.setMonth(startDate.getMonth() - 6);
          break;
        case '12months':
          startDate.setMonth(startDate.getMonth() - 12);
          break;
        case '24months':
          startDate.setMonth(startDate.getMonth() - 24);
          break;
        default:
          startDate.setMonth(startDate.getMonth() - 6);
      }
      
      return {
        start: startDate.toISOString().split('T')[0],
        end: endDate.toISOString().split('T')[0]
      };
    };

    const dateRange = getDateRange(timeframe);

    // Fetch snapshots from the date range
    let snapshots = await base44.asServiceRole.entities.AnalyticsSnapshot.list('-snapshot_date');
    
    // Filter by date range
    snapshots = snapshots.filter(s => 
      s.snapshot_date >= dateRange.start && s.snapshot_date <= dateRange.end
    );

    // If no snapshots exist, return synthetic data with a message
    if (snapshots.length === 0) {
      return Response.json({
        success: true,
        message: 'No historical snapshots found. Displaying synthetic trend data.',
        is_synthetic: true,
        data: generateSyntheticTrends(timeframe)
      });
    }

    // Transform snapshots into trend data
    const trendData = snapshots.map(snapshot => {
      const date = new Date(snapshot.snapshot_date);
      const monthLabel = date.toLocaleDateString('en-US', { 
        month: 'short', 
        year: timeframe === '24months' ? '2-digit' : undefined 
      });

      return {
        month: monthLabel,
        date: snapshot.snapshot_date,
        overall: snapshot.avg_si_score || 0,
        decision_making: snapshot.competency_averages?.decision_making || 0,
        communication: snapshot.competency_averages?.communication || 0,
        resource_management: snapshot.competency_averages?.resource_management || 0,
        stakeholder_management: snapshot.competency_averages?.stakeholder_management || 0,
        performance_management: snapshot.competency_averages?.performance_management || 0,
        total_leaders: snapshot.total_leaders || 0,
        ready_now: snapshot.ready_now || 0,
        high_potential: snapshot.high_potential || 0,
        at_risk: snapshot.at_risk || 0,
        bench_strength: snapshot.bench_strength || 0,
        pipeline_strength: snapshot.pipeline_strength || 0
      };
    });

    return Response.json({
      success: true,
      is_synthetic: false,
      data: trendData,
      snapshot_count: snapshots.length,
      date_range: dateRange
    });

  } catch (error) {
    console.error('Error fetching historical trends:', error);
    return Response.json({ 
      success: false,
      error: error.message 
    }, { status: 500 });
  }
});

// Helper function to generate synthetic trend data when no snapshots exist
function generateSyntheticTrends(timeframe) {
  const getMonthsCount = (tf) => {
    switch(tf) {
      case '3months': return 3;
      case '6months': return 6;
      case '12months': return 12;
      case '24months': return 24;
      default: return 6;
    }
  };

  const monthsCount = getMonthsCount(timeframe);
  const trendData = [];
  
  // Base values
  const baseValues = {
    overall: 72,
    decision_making: 70,
    communication: 75,
    resource_management: 68,
    stakeholder_management: 73,
    performance_management: 71
  };

  for (let i = monthsCount - 1; i >= 0; i--) {
    const date = new Date();
    date.setMonth(date.getMonth() - i);
    const monthLabel = date.toLocaleDateString('en-US', { 
      month: 'short', 
      year: i > 11 ? '2-digit' : undefined 
    });
    
    // Add realistic variance
    const variance = (Math.random() - 0.5) * 8;
    
    trendData.push({
      month: monthLabel,
      date: date.toISOString().split('T')[0],
      overall: Math.max(0, Math.min(100, baseValues.overall + variance)),
      decision_making: Math.max(0, Math.min(100, baseValues.decision_making + variance)),
      communication: Math.max(0, Math.min(100, baseValues.communication + variance)),
      resource_management: Math.max(0, Math.min(100, baseValues.resource_management + variance)),
      stakeholder_management: Math.max(0, Math.min(100, baseValues.stakeholder_management + variance)),
      performance_management: Math.max(0, Math.min(100, baseValues.performance_management + variance))
    });
  }

  return trendData;
}