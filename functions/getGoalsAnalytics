import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

Deno.serve(async (req) => {
  try {
    const base44 = createClientFromRequest(req);
    
    // Authenticate and authorize
    const user = await base44.auth.me();
    
    if (!user) {
      return Response.json({ 
        success: false, 
        error: 'Unauthorized - Authentication required' 
      }, { status: 401 });
    }

    // Only Platform Admin and Super Admin can access goals analytics
    if (user.app_role !== 'Platform Admin' && user.app_role !== 'Super Administrator') {
      return Response.json({ 
        success: false, 
        error: 'Unauthorized - Platform Admin or Super Admin only' 
      }, { status: 403 });
    }

    console.log('Fetching goals analytics for:', user.email, user.app_role);

    // Parse filters from request body
    const body = await req.json().catch(() => ({}));
    const {
      time_range = '30d',
      client_id = 'all',
      department = 'all',
      goal_category = 'all',
      goal_status = 'all',
      manager_email = 'all'
    } = body;

    // Calculate date cutoff
    const getCutoffDate = (range) => {
      const now = new Date();
      switch(range) {
        case '7d': return new Date(now.setDate(now.getDate() - 7));
        case '30d': return new Date(now.setDate(now.getDate() - 30));
        case '90d': return new Date(now.setDate(now.getDate() - 90));
        case '12mo': return new Date(now.setFullYear(now.getFullYear() - 1));
        case 'all': return new Date(0);
        default: return new Date(now.setDate(now.getDate() - 30));
      }
    };
    
    const cutoffDate = getCutoffDate(time_range);

    // Fetch data using regular entity access
    const [users, clients, goals] = await Promise.all([
      base44.entities.User.list().catch(() => []),
      base44.entities.Client.list().catch(() => []),
      base44.entities.Goal.list().catch(() => [])
    ]);

    // Apply role-based filtering
    let scopedUsers = users;
    let scopedClients = clients;
    let scopedGoals = goals;

    if (user.app_role === 'Super Administrator') {
      // Super Admin: Only their organization and partner clients
      if (user.client_id) {
        // Get current client
        const currentClient = clients.find(c => c.id === user.client_id);
        
        if (currentClient?.type === 'partner_client' && currentClient.partner_id) {
          // If part of a partner, show all partner clients
          scopedClients = clients.filter(c => c.partner_id === currentClient.partner_id);
        } else {
          // Otherwise just their organization
          scopedClients = clients.filter(c => c.id === user.client_id);
        }
        
        const clientIds = scopedClients.map(c => c.id);
        scopedUsers = users.filter(u => clientIds.includes(u.client_id));
        
        const userEmails = scopedUsers.map(u => u.email);
        scopedGoals = goals.filter(g => userEmails.includes(g.user_email));
      }
    }
    // Platform Admin sees everything (no filtering needed)

    // Apply user-selected filters
    if (client_id !== 'all') {
      scopedUsers = scopedUsers.filter(u => u.client_id === client_id);
      const userEmails = scopedUsers.map(u => u.email);
      scopedGoals = scopedGoals.filter(g => userEmails.includes(g.user_email));
    }

    if (department !== 'all') {
      const departmentUsers = scopedUsers.filter(u => u.department === department);
      const userEmails = departmentUsers.map(u => u.email);
      scopedGoals = scopedGoals.filter(g => userEmails.includes(g.user_email));
    }

    if (goal_category !== 'all') {
      scopedGoals = scopedGoals.filter(g => g.category === goal_category);
    }

    if (goal_status !== 'all') {
      scopedGoals = scopedGoals.filter(g => g.status === goal_status);
    }

    if (manager_email !== 'all') {
      scopedGoals = scopedGoals.filter(g => g.assigned_by === manager_email);
    }

    // Filter by time range
    scopedGoals = scopedGoals.filter(g => {
      const createdDate = new Date(g.created_date);
      return createdDate >= cutoffDate;
    });

    // Calculate metrics
    const totalGoals = scopedGoals.length;
    const completedGoals = scopedGoals.filter(g => g.status === 'completed').length;
    const overdueGoals = scopedGoals.filter(g => g.status === 'overdue').length;
    const atRiskGoals = scopedGoals.filter(g => g.status === 'at_risk').length;
    const pendingAcceptance = scopedGoals.filter(g => g.status === 'pending_acceptance').length;
    const activeGoals = scopedGoals.filter(g => ['active', 'at_risk'].includes(g.status));
    
    const avgCompletion = activeGoals.length > 0
      ? Math.round(activeGoals.reduce((sum, g) => sum + (g.completion_percentage || 0), 0) / activeGoals.length)
      : 0;
    
    const completionRate = totalGoals > 0
      ? Math.round((completedGoals / totalGoals) * 100)
      : 0;

    // Goals by status
    const goalsByStatus = {
      active: scopedGoals.filter(g => g.status === 'active').length,
      completed: completedGoals,
      overdue: overdueGoals,
      at_risk: atRiskGoals,
      pending_acceptance: pendingAcceptance,
      declined: scopedGoals.filter(g => g.status === 'declined').length
    };

    // Goals by category
    const goalsByCategory = scopedGoals.reduce((acc, g) => {
      const cat = g.category || 'uncategorized';
      acc[cat] = (acc[cat] || 0) + 1;
      return acc;
    }, {});

    // Activity trend (last 30 days)
    const activityTrend = [];
    for (let i = 29; i >= 0; i--) {
      const date = new Date();
      date.setDate(date.getDate() - i);
      const dateStr = date.toISOString().split('T')[0];
      
      const created = scopedGoals.filter(g => {
        const gDate = new Date(g.created_date).toISOString().split('T')[0];
        return gDate === dateStr;
      }).length;
      
      const completed = scopedGoals.filter(g => {
        if (!g.updated_date || g.status !== 'completed') return false;
        const gDate = new Date(g.updated_date).toISOString().split('T')[0];
        return gDate === dateStr;
      }).length;
      
      activityTrend.push({
        date: dateStr,
        created,
        completed
      });
    }

    // Top achievers
    const userGoalStats = {};
    scopedGoals.forEach(g => {
      if (!userGoalStats[g.user_email]) {
        const userInfo = scopedUsers.find(u => u.email === g.user_email);
        userGoalStats[g.user_email] = {
          email: g.user_email,
          full_name: userInfo?.full_name || g.user_email,
          department: userInfo?.department || 'Unknown',
          total: 0,
          completed: 0,
          completionRate: 0
        };
      }
      userGoalStats[g.user_email].total++;
      if (g.status === 'completed') {
        userGoalStats[g.user_email].completed++;
      }
    });

    const topAchievers = Object.values(userGoalStats)
      .map(stat => ({
        ...stat,
        completionRate: stat.total > 0 ? Math.round((stat.completed / stat.total) * 100) : 0
      }))
      .sort((a, b) => b.completionRate - a.completionRate || b.completed - a.completed)
      .slice(0, 10);

    // Overdue goals
    const overdueGoalsList = scopedGoals
      .filter(g => g.status === 'overdue')
      .map(g => {
        const userInfo = scopedUsers.find(u => u.email === g.user_email);
        const dueDate = new Date(g.due_date);
        const today = new Date();
        const daysOverdue = Math.floor((today.getTime() - dueDate.getTime()) / (1000 * 60 * 60 * 24));
        
        return {
          id: g.id,
          title: g.title,
          user_email: g.user_email,
          user_name: userInfo?.full_name || g.user_email,
          due_date: g.due_date,
          daysOverdue,
          category: g.category,
          completion_percentage: g.completion_percentage || 0
        };
      })
      .sort((a, b) => b.daysOverdue - a.daysOverdue);

    // At risk goals
    const atRiskGoalsList = scopedGoals
      .filter(g => g.status === 'at_risk')
      .map(g => {
        const userInfo = scopedUsers.find(u => u.email === g.user_email);
        return {
          id: g.id,
          title: g.title,
          user_email: g.user_email,
          user_name: userInfo?.full_name || g.user_email,
          due_date: g.due_date,
          category: g.category,
          completion_percentage: g.completion_percentage || 0
        };
      })
      .sort((a, b) => a.completion_percentage - b.completion_percentage);

    // Department performance
    const departmentStats = {};
    scopedGoals.forEach(g => {
      const userInfo = scopedUsers.find(u => u.email === g.user_email);
      const dept = userInfo?.department || 'Unknown';
      
      if (!departmentStats[dept]) {
        departmentStats[dept] = {
          total: 0,
          completed: 0,
          overdue: 0,
          at_risk: 0
        };
      }
      
      departmentStats[dept].total++;
      if (g.status === 'completed') departmentStats[dept].completed++;
      if (g.status === 'overdue') departmentStats[dept].overdue++;
      if (g.status === 'at_risk') departmentStats[dept].at_risk++;
    });

    const departmentPerformance = Object.entries(departmentStats)
      .map(([dept, stats]) => ({
        department: dept,
        ...stats,
        completionRate: stats.total > 0 ? Math.round((stats.completed / stats.total) * 100) : 0
      }))
      .sort((a, b) => b.completionRate - a.completionRate);

    // Available filter options
    const availableClients = scopedClients.map(c => ({ id: c.id, name: c.name }));
    const availableDepartments = [...new Set(scopedUsers.map(u => u.department).filter(Boolean))].sort();
    const availableManagers = [...new Set(scopedGoals.map(g => g.assigned_by).filter(Boolean))].sort();

    return Response.json({
      success: true,
      data: {
        metrics: {
          totalGoals,
          completedGoals,
          completionRate,
          overdueGoals,
          atRiskGoals,
          avgCompletion,
          pendingAcceptance
        },
        goalsByStatus,
        goalsByCategory,
        activityTrend,
        topAchievers,
        overdueGoalsList,
        atRiskGoalsList,
        departmentPerformance,
        availableClients,
        availableDepartments,
        availableManagers
      }
    });

  } catch (error) {
    console.error('Error in getGoalsAnalytics:', error);
    return Response.json({ 
      success: false,
      error: error.message || 'Failed to fetch goals analytics' 
    }, { status: 500 });
  }
});