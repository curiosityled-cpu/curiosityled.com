import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

Deno.serve(async (req) => {
  try {
    const base44 = createClientFromRequest(req);
    const user = await base44.auth.me();

    if (!user || user.app_role !== 'Platform Admin') {
      return Response.json({ error: 'Unauthorized - Platform Admin only' }, { status: 401 });
    }

    const { client_id, ...updateData } = await req.json();

    if (!client_id) {
      return Response.json({ error: 'client_id is required' }, { status: 400 });
    }

    // Update client
    const client = await base44.entities.Client.update(client_id, updateData);

    return Response.json({ 
      client,
      message: 'Client updated successfully' 
    });

  } catch (error) {
    console.error('Error updating client:', error);
    return Response.json({ 
      error: error.message || 'Failed to update client' 
    }, { status: 500 });
  }
});