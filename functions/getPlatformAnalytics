import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

Deno.serve(async (req) => {
  try {
    const base44 = createClientFromRequest(req);
    
    // Authenticate and authorize
    const user = await base44.auth.me();
    
    if (!user) {
      return Response.json({ 
        success: false, 
        error: 'Unauthorized - Authentication required' 
      }, { status: 401 });
    }

    // Only Platform Admin can access platform analytics
    if (user.app_role !== 'Platform Admin') {
      return Response.json({ 
        success: false, 
        error: 'Unauthorized - Platform Admin only',
        details: 'This endpoint requires Platform Admin privileges'
      }, { status: 403 });
    }

    console.log('Fetching platform analytics for Platform Admin:', user.email);

    // Helper function to safely fetch with timeout
    const fetchWithTimeout = async (promise, timeoutMs = 10000, entityName = 'data') => {
      const timeoutPromise = new Promise((_, reject) => 
        setTimeout(() => reject(new Error(`Timeout fetching ${entityName}`)), timeoutMs)
      );
      
      try {
        return await Promise.race([promise, timeoutPromise]);
      } catch (error) {
        console.error(`Error fetching ${entityName}:`, error.message);
        return [];
      }
    };

    // Fetch all data with individual error handling and timeouts
    console.log('Starting data fetch...');
    
    const [
      users,
      clients,
      assessments,
      goals,
      assignedLearning,
      programs,
      activityLogs
    ] = await Promise.all([
      fetchWithTimeout(
        base44.entities.User.list(),
        10000,
        'Users'
      ),
      fetchWithTimeout(
        base44.entities.Client.list(),
        10000,
        'Clients'
      ),
      fetchWithTimeout(
        base44.entities.Assessment.list(),
        10000,
        'Assessments'
      ),
      fetchWithTimeout(
        base44.entities.Goal.list(),
        10000,
        'Goals'
      ),
      fetchWithTimeout(
        base44.entities.AssignedLearning.list(),
        10000,
        'Assigned Learning'
      ),
      fetchWithTimeout(
        base44.entities.Program.list(),
        10000,
        'Programs'
      ),
      fetchWithTimeout(
        base44.entities.ActivityLog.list('-timestamp', 100),
        10000,
        'Activity Logs'
      )
    ]);

    console.log('Data fetched successfully:', {
      users: users?.length || 0,
      clients: clients?.length || 0,
      assessments: assessments?.length || 0,
      goals: goals?.length || 0,
      assignedLearning: assignedLearning?.length || 0,
      programs: programs?.length || 0,
      activityLogs: activityLogs?.length || 0
    });

    // Return the data (ensuring arrays)
    return Response.json({
      success: true,
      data: {
        users: Array.isArray(users) ? users : [],
        organizations: Array.isArray(clients) ? clients : [],
        assessments: Array.isArray(assessments) ? assessments : [],
        goals: Array.isArray(goals) ? goals : [],
        assignedLearning: Array.isArray(assignedLearning) ? assignedLearning : [],
        programs: Array.isArray(programs) ? programs : [],
        activityLogs: Array.isArray(activityLogs) ? activityLogs : []
      }
    });

  } catch (error) {
    console.error('Error in getPlatformAnalytics:', error);
    
    // Return a structured error response
    return Response.json({ 
      success: false,
      error: error.message || 'Failed to fetch platform analytics',
      details: error.stack || 'Unknown error',
      data: {
        users: [],
        organizations: [],
        assessments: [],
        goals: [],
        assignedLearning: [],
        programs: [],
        activityLogs: []
      }
    }, { status: 500 });
  }
});