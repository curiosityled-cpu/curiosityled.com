import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

Deno.serve(async (req) => {
  try {
    const base44 = createClientFromRequest(req);
    const user = await base44.auth.me();

    if (!user) {
      return Response.json({ error: 'Unauthorized' }, { status: 401 });
    }

    // Platform Admin can see all partners
    // Partner Business Admin can see their own partner
    if (user.app_role !== 'Platform Admin' && user.app_role !== 'Partner Business Administrator') {
      return Response.json({ error: 'Unauthorized - Admin access required' }, { status: 403 });
    }

    console.log('Fetching partners for:', user.email, user.app_role);

    // Use regular entity access (RLS will handle permissions)
    let partners = [];
    try {
      partners = await base44.entities.Partner.list('-created_date');
      console.log('Successfully fetched', partners.length, 'partners');
    } catch (error) {
      console.error('Error fetching partners:', error);
      return Response.json({ 
        error: 'Unable to fetch partners. Please ensure proper permissions are configured.',
        details: error.message,
        partners: []
      }, { status: 200 });
    }

    return Response.json({ partners: partners || [] });

  } catch (error) {
    console.error('Error listing partners:', error);
    return Response.json({ 
      error: error.message || 'Failed to list partners',
      partners: []
    }, { status: 200 });
  }
});