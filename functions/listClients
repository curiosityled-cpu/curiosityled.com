import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

Deno.serve(async (req) => {
  try {
    const base44 = createClientFromRequest(req);
    const user = await base44.auth.me();

    if (!user) {
      return Response.json({ error: 'Unauthorized' }, { status: 401 });
    }

    // Platform Admin can see all clients
    // Partner Business Admin can see their partner's clients
    if (user.app_role !== 'Platform Admin' && user.app_role !== 'Partner Business Administrator') {
      return Response.json({ error: 'Unauthorized - Admin access required' }, { status: 403 });
    }

    console.log('Fetching clients for:', user.email, user.app_role);

    // Use regular entity access (RLS will handle permissions)
    let clients = [];
    try {
      clients = await base44.entities.Client.list('-created_date');
      console.log('Successfully fetched', clients.length, 'clients');
    } catch (error) {
      console.error('Error fetching clients:', error);
      return Response.json({ 
        error: 'Unable to fetch clients. Please ensure proper permissions are configured.',
        details: error.message,
        clients: []
      }, { status: 200 });
    }

    return Response.json({ clients: clients || [] });

  } catch (error) {
    console.error('Error listing clients:', error);
    return Response.json({ 
      error: error.message || 'Failed to list clients',
      clients: []
    }, { status: 200 });
  }
});